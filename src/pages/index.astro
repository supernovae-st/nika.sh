---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const changelogEntries = (await getCollection('changelog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Nika"
  description="Nika is a semantic workflow engine for AI agents. One YAML file, five verbs, nine providers. Single Rust binary. AGPL."
  section=""
>
  {/* ========================================================================
      HERO — modern, blue brand, mesh gradient, terminal demo on the right
      ======================================================================== */}
  <section class="relative overflow-hidden">
    <div class="mesh-bg" aria-hidden="true"></div>
    <div class="grid-floor" aria-hidden="true"></div>
    <div class="dither-overlay" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-[78rem] px-6 pt-24 pb-32 md:pt-32 md:pb-40">
      <div class="grid lg:grid-cols-[1.05fr_1fr] gap-12 lg:gap-20 items-center">

        {/* LEFT — copy + CTAs */}
        <div>
          <a href="/changelog/" class="badge mb-8">
            <span class="dot"></span>
            <span>Week 22 · nika-catalog-verify admitted</span>
            <span aria-hidden="true">→</span>
          </a>

          <h1 class="text-gradient text-5xl sm:text-6xl lg:text-7xl font-semibold tracking-[-0.04em] leading-[1.0] mb-7">
            Workflows for AI<br/>
            <span class="text-gradient-blue">in a single YAML file.</span>
          </h1>

          <p class="text-lg lg:text-[1.15rem] text-[var(--color-fg-mute)] mb-10 max-w-[44ch] leading-relaxed">
            A semantic workflow engine for AI agents. Five verbs, nine providers,
            one Rust binary. AGPL — yours forever, runs on your laptop.
          </p>

          <div class="flex flex-wrap gap-3 items-center">
            <a href="/install/" class="btn-primary">
              Install Nika
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="/method/" class="btn-ghost">
              Read the method
            </a>
          </div>

          <div class="mt-12 flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-[var(--color-fg-dim)]">
            <span>AGPL-3.0</span>
            <span class="opacity-30">·</span>
            <span>Rust</span>
            <span class="opacity-30">·</span>
            <span>macOS · Linux</span>
            <span class="opacity-30">·</span>
            <span>9 providers</span>
            <span class="opacity-30">·</span>
            <span>Open source</span>
          </div>
        </div>

        {/* RIGHT — terminal demo */}
        <div class="terminal lg:translate-y-2">
          <div class="terminal-bar">
            <span class="terminal-dot red"></span>
            <span class="terminal-dot yellow"></span>
            <span class="terminal-dot green"></span>
            <span class="terminal-title">~/triage · nika</span>
          </div>
          <div class="terminal-body"><span class="terminal-prompt">$</span>nika run triage.nika.yaml

<span class="terminal-cmt"># 4 tasks, 1.42s</span>
<span class="terminal-out">▸</span> <span class="terminal-key">fetch</span>   issue.json        <span class="terminal-out">200 · 42ms</span>
<span class="terminal-out">▸</span> <span class="terminal-key">infer</span>   classify          <span class="terminal-str">claude-opus-4-6</span>
  <span class="terminal-out">└</span> <span class="terminal-str">"label: bug, priority: high"</span>
<span class="terminal-out">▸</span> <span class="terminal-key">invoke</span>  gh.label          <span class="terminal-str">"bug"</span> <span class="terminal-str">"P1"</span>
<span class="terminal-out">▸</span> <span class="terminal-key">infer</span>   reply             <span class="terminal-str">claude-opus-4-6</span>
  <span class="terminal-out">└</span> <span class="terminal-str">streaming</span><span class="terminal-cursor">&nbsp;</span>

<span class="terminal-out">✓ workflow complete</span>
</div>
        </div>
      </div>
    </div>
  </section>

  {/* ========================================================================
      VALUE PROP — three clean cards, no mono fatigue, no §-labels
      ======================================================================== */}
  <section class="border-t border-[var(--color-border)] bg-[var(--color-bg)]">
    <div class="mx-auto max-w-[78rem] px-6 py-24 md:py-32">
      <div class="max-w-2xl mb-16">
        <h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4 text-[var(--color-fg)]">
          One file, the whole pipeline.
        </h2>
        <p class="text-lg text-[var(--color-fg-mute)] leading-relaxed">
          The same YAML is read by the engine and understood by the human. No DSL,
          no callbacks scattered across nodes, no Python pretending to be config.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        <div class="card">
          <div class="w-10 h-10 mb-5 flex items-center justify-center rounded-lg bg-[var(--color-brand-soft)]/30 border border-[var(--color-brand)]/30">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-brand)]">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2 text-[var(--color-fg)]">Semantic</h3>
          <p class="text-[var(--color-fg-mute)] text-[0.9375rem] leading-relaxed">
            Five verbs cover everything: <code class="inline-code">exec</code>, <code class="inline-code">fetch</code>, <code class="inline-code">invoke</code>, <code class="inline-code">infer</code>, <code class="inline-code">agent</code>. Closed set. The schema is the contract.
          </p>
        </div>

        <div class="card">
          <div class="w-10 h-10 mb-5 flex items-center justify-center rounded-lg bg-[var(--color-brand-soft)]/30 border border-[var(--color-brand)]/30">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-brand)]">
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-3.086-3.086a2 2 0 00-2.828 0L6 21"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2 text-[var(--color-fg)]">Sovereign</h3>
          <p class="text-[var(--color-fg-mute)] text-[0.9375rem] leading-relaxed">
            One Rust binary. Zero daemon. Your keys in your keychain. Any provider —
            Anthropic, OpenAI, Google, Mistral, Ollama, local GGUF. AGPL forever.
          </p>
        </div>

        <div class="card">
          <div class="w-10 h-10 mb-5 flex items-center justify-center rounded-lg bg-[var(--color-brand-soft)]/30 border border-[var(--color-brand)]/30">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-brand)]">
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2 text-[var(--color-fg)]">Crafted</h3>
          <p class="text-[var(--color-fg-mute)] text-[0.9375rem] leading-relaxed">
            Every crate passes 12 gates. Mutation tested ≥ 90%. Zero
            <code class="inline-code">.unwrap()</code> in production. Built in public, week by week.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ========================================================================
      SHOW THE CODE — proper code block, no ASCII boxes
      ======================================================================== */}
  <section class="border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-[78rem] px-6 py-24 md:py-32">
      <div class="grid lg:grid-cols-[1fr_1.4fr] gap-12 lg:gap-16 items-start">
        <div>
          <span class="text-sm text-[var(--color-brand)] font-medium mb-3 block">A workflow</span>
          <h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-5 text-[var(--color-fg)]">
            Workflows are text.
          </h2>
          <p class="text-[var(--color-fg-mute)] leading-relaxed mb-6">
            A task has an <code class="inline-code">id</code>, one verb, and optional
            <code class="inline-code">depends_on</code>. Tasks form a DAG. Nika executes
            in topological order, parallelizes what it can, streams events as it goes.
          </p>
          <a href="/method/" class="btn-ghost">
            Read the method
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <div class="terminal">
          <div class="terminal-bar">
            <span class="terminal-dot red"></span>
            <span class="terminal-dot yellow"></span>
            <span class="terminal-dot green"></span>
            <span class="terminal-title">triage.nika.yaml</span>
          </div>
          <div class="terminal-body"><span class="terminal-key">schema</span>: nika/workflow@<span class="terminal-str">0.12</span>
<span class="terminal-key">workflow</span>: triage

<span class="terminal-key">tasks</span>:
  - <span class="terminal-key">id</span>: classify
    <span class="terminal-key">infer</span>:
      <span class="terminal-key">provider</span>: anthropic
      <span class="terminal-key">model</span>: claude-opus-4-6
      <span class="terminal-key">prompt</span>: <span class="terminal-str">"Classify this issue: &#123;&#123; inputs.body &#125;&#125;"</span>
      <span class="terminal-key">structured</span>: &#123; <span class="terminal-key">label</span>: string, <span class="terminal-key">priority</span>: enum &#125;

  - <span class="terminal-key">id</span>: label
    <span class="terminal-key">depends_on</span>: [classify]
    <span class="terminal-key">invoke</span>:
      <span class="terminal-key">tool</span>: gh.label
      <span class="terminal-key">input</span>: <span class="terminal-str">"&#123;&#123; tasks.classify.output &#125;&#125;"</span>
</div>
        </div>
      </div>
    </div>
  </section>

  {/* ========================================================================
      STATS — minimal, clean
      ======================================================================== */}
  <section class="border-t border-[var(--color-border)] bg-[var(--color-surface)]/30">
    <div class="mx-auto max-w-[78rem] px-6 py-20">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div>
          <div class="text-3xl md:text-4xl font-semibold text-[var(--color-fg)] mb-1">
            5<span class="text-[var(--color-fg-dim)]">/40</span>
          </div>
          <div class="text-sm text-[var(--color-fg-mute)]">Organs admitted</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-semibold text-[var(--color-fg)] mb-1">10,434</div>
          <div class="text-sm text-[var(--color-fg-mute)]">Lines of Rust</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-semibold text-[var(--color-fg)] mb-1">369</div>
          <div class="text-sm text-[var(--color-fg-mute)]">Tests</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-semibold text-[var(--color-green)] mb-1">0</div>
          <div class="text-sm text-[var(--color-fg-mute)]">.unwrap() in src</div>
        </div>
      </div>
    </div>
  </section>

  {/* ========================================================================
      RECENT DEV LOGS — clean cards, no labels overload
      ======================================================================== */}
  {changelogEntries.length > 0 && (
    <section class="border-t border-[var(--color-border)]">
      <div class="mx-auto max-w-[78rem] px-6 py-24 md:py-32">
        <div class="flex items-end justify-between mb-12 flex-wrap gap-4">
          <div>
            <span class="text-sm text-[var(--color-brand)] font-medium mb-3 block">Built in public</span>
            <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-[var(--color-fg)]">
              Latest dev logs
            </h2>
          </div>
          <a href="/changelog/" class="text-[var(--color-brand)] hover:text-[var(--color-brand-hover)] text-sm font-medium">
            All logs →
          </a>
        </div>

        <div class="grid gap-5 md:grid-cols-3">
          {changelogEntries.map((entry) => (
            <a href={`/changelog/${entry.id}/`} class="card group">
              <div class="text-xs text-[var(--color-fg-dim)] mb-3">
                Week {String(entry.data.week).padStart(2, '0')} · {entry.data.date.toISOString().slice(0, 10)}
              </div>
              <h3 class="text-lg font-semibold mb-2 text-[var(--color-fg)] group-hover:text-[var(--color-brand)] transition-colors">
                {entry.data.title}
              </h3>
              <p class="text-sm text-[var(--color-fg-mute)] line-clamp-3 leading-relaxed">
                {entry.data.summary}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ========================================================================
      CTA — one clean strip
      ======================================================================== */}
  <section class="border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-[78rem] px-6 py-24 md:py-28 text-center">
      <h2 class="text-3xl md:text-5xl font-semibold tracking-tight mb-5 text-gradient">
        Built in public.<br/>
        <span class="text-gradient-blue">Read the commits.</span>
      </h2>
      <p class="text-lg text-[var(--color-fg-mute)] mb-10 max-w-xl mx-auto">
        Every Friday at 18:00 Paris we publish what grew that week. Honest numbers, real commits.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="https://github.com/supernovae-st/nika" class="btn-primary">
          github.com/supernovae-st/nika
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M5 3h6v6M11 3l-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/changelog/" class="btn-ghost">
          Latest dev log
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
