---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import HeroDots from '~/components/react/HeroDots';
import CountUp from '~/components/react/CountUp';
import Reveal from '~/components/react/Reveal';
import RevealText from '~/components/react/RevealText';

const changelogEntries = (await getCollection('changelog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Nika"
  description="Nika is alive. A semantic YAML workflow engine for AI — growing in public inside a glass chrysalis. AGPL, Rust, Paris."
  section=""
>
  {/* ========================================================================
      HERO — modern Linear-grade. Mesh gradient + grid floor + dither overlay.
      Big gradient headline, clear value prop, real animated terminal demo.
      ======================================================================== */}
  <section class="relative overflow-hidden min-h-[92vh] flex items-center">
    {/* Layered backgrounds — mesh gradient, grid, subtle dither */}
    <div class="mesh-bg" aria-hidden="true"></div>
    <div class="grid-floor" aria-hidden="true"></div>
    <div class="dither-overlay" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-[72rem] px-6 pt-24 pb-28 md:pt-32 md:pb-36 w-full">
      <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center">

        {/* LEFT — copy + CTAs */}
        <div>
          {/* Live status badge */}
          <a href="/changelog" class="badge mb-8 hover:border-[var(--color-nika-orange)] transition-colors">
            <span class="dot"></span>
            <span>Week 22 — nika-catalog-verify admitted</span>
            <span aria-hidden="true">→</span>
          </a>

          {/* Headline — gradient text, big, modern */}
          <h1 class="text-gradient text-5xl sm:text-6xl lg:text-7xl font-bold tracking-[-0.04em] leading-[0.95] mb-6">
            Workflows for AI<br/>
            <span class="text-gradient-warm">in a single YAML file.</span>
          </h1>

          {/* Subtitle — clear, friendly, direct */}
          <p class="text-lg lg:text-xl text-[var(--color-bone-mute)] mb-10 max-w-[40ch] leading-relaxed">
            Nika is a semantic workflow engine for AI agents. One file, five verbs,
            nine providers. Single Rust binary. AGPL — yours forever.
          </p>

          <div class="flex flex-wrap gap-3 items-center">
            <a href="/install/" class="btn-primary">
              Install Nika
              <span aria-hidden="true">→</span>
            </a>
            <a href="/method/" class="btn-ghost">
              Read the method
            </a>
          </div>

          {/* Trust strip */}
          <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-3 text-xs text-[var(--color-dim-star)]">
            <span class="font-mono">AGPL-3.0</span>
            <span class="font-mono">Rust</span>
            <span class="font-mono">macOS · Linux</span>
            <span class="font-mono">9 providers</span>
            <span class="font-mono">Anthropic · OpenAI · Ollama · GGUF</span>
          </div>
        </div>

        {/* RIGHT — animated terminal demo */}
        <div class="terminal">
          <div class="terminal-bar">
            <span class="terminal-dot red"></span>
            <span class="terminal-dot yellow"></span>
            <span class="terminal-dot green"></span>
            <span class="terminal-title">~/projects/triage · nika</span>
          </div>
          <div class="terminal-body">
<span class="terminal-prompt">$</span>nika run triage.nika.yaml

<span class="terminal-out">▶</span> <span class="terminal-key">fetch</span>     issue.json        <span class="terminal-out">200</span> <span class="terminal-out">42ms</span>
<span class="terminal-out">▶</span> <span class="terminal-key">infer</span>     classify          <span class="terminal-str">claude-opus-4-6</span>
  <span class="terminal-out">└─</span> <span class="terminal-str">"label: bug, priority: high"</span>
<span class="terminal-out">▶</span> <span class="terminal-key">invoke</span>    gh.label          <span class="terminal-str">"bug"</span> <span class="terminal-str">"P1"</span>
<span class="terminal-out">▶</span> <span class="terminal-key">infer</span>     reply             <span class="terminal-str">claude-opus-4-6</span>
  <span class="terminal-out">└─</span> <span class="terminal-str">streaming…</span><span class="terminal-cursor">&nbsp;</span>

<span class="terminal-out">✓ workflow complete · 1.42s · 4 tasks</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========================================================================
      VALUE PROP — three nouns, Linear-restraint, mono labels
      ======================================================================== */}
  <section class="border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-[72rem] px-6 py-20 md:py-28 grid gap-10 md:grid-cols-3">
      <article class="space-y-3">
        <span class="annotation annotation-orange">§ 01 · SEMANTIC</span>
        <h2 class="font-mono text-2xl leading-tight text-[var(--color-bone)]">
          Workflows you can read.
        </h2>
        <p class="text-[var(--color-bone-mute)]">
          One <code class="font-mono text-sm px-1 bg-[var(--color-space-sunken)] border border-[var(--color-border)]">.nika.yaml</code> file.
          Same source for the machine and the human. No DSL. No YAML-that-pretends-to-be-Python.
          The schema is the contract.
        </p>
      </article>

      <article class="space-y-3">
        <span class="annotation annotation-orange">§ 02 · SOVEREIGN</span>
        <h2 class="font-mono text-2xl leading-tight text-[var(--color-bone)]">
          Runs on your laptop.
        </h2>
        <p class="text-[var(--color-bone-mute)]">
          Rust binary. Zero daemon. Your keys in your keychain. Any provider —
          Anthropic, OpenAI, Ollama, local GGUF. No SaaS dependency. No vendor lock-in.
          AGPL, so it stays that way.
        </p>
      </article>

      <article class="space-y-3">
        <span class="annotation annotation-orange">§ 03 · SLOW</span>
        <h2 class="font-mono text-2xl leading-tight text-[var(--color-bone)]">
          34 organs over a year.
        </h2>
        <p class="text-[var(--color-bone-mute)]">
          Every crate passes 12 gates before admission. Mutation tested ≥ 90%.
          No <code class="font-mono text-sm px-1 bg-[var(--color-space-sunken)] border border-[var(--color-border)]">.unwrap()</code> in src.
          If it can't explain itself in 1500 lines, it gets split. Slow on purpose.
        </p>
      </article>
    </div>
  </section>

  {/* ========================================================================
      TERMINAL DEMO PREVIEW — a single .nika.yaml block, typeset as terminal
      ======================================================================== */}
  <section class="border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-[72rem] px-6 py-20">
      <div class="grid gap-10 md:grid-cols-[14rem_1fr]">
        <div>
          <span class="annotation annotation-dim block mb-3">
            FIG 01 · HELLO.NIKA.YAML
          </span>
          <p class="text-[var(--color-bone-mute)] text-sm">
            A workflow is a text file. The verbs are <code class="font-mono">exec</code>, <code class="font-mono">fetch</code>, <code class="font-mono">invoke</code>, <code class="font-mono">infer</code>, <code class="font-mono">agent</code>. Everything else is data.
          </p>
        </div>
        <pre class="terminal-frame"><code>┌─ hello.nika.yaml ──────────────────────────────┐
│                                                │
│  schema: nika/workflow@0.12                    │
│  workflow: hello                               │
│                                                │
│  tasks:                                        │
│    - id: greet                                 │
│      infer:                                    │
│        provider: anthropic                     │
│        model: claude-opus-4-6                  │
│        prompt: "Say hi to the chrysalis."      │
│                                                │
│  ▊                                             │
│                                                │
└────────────────────────────────────────────────┘</code></pre>
      </div>
    </div>
  </section>

  {/* ========================================================================
      CHRYSALIS PROGRESS — the organism's vital signs, real numbers
      ======================================================================== */}
  <section class="border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-[72rem] px-6 py-20 md:py-28">
      <Reveal>
        <span class="annotation annotation-dim block mb-2">§ 04 · VITAL SIGNS</span>
        <h2 class="font-mono text-2xl leading-tight mb-10">Inside the chrysalis</h2>
      </Reveal>

      <div class="grid gap-6 md:grid-cols-4 mb-12">
        <Reveal delay={0.0}>
          <div class="border border-[var(--color-border)] p-6 hover:border-[var(--color-nika-orange)] transition-colors">
            <span class="font-mono text-4xl md:text-5xl text-[var(--color-nika-orange)] tabular-nums">
              <CountUp client:visible to={5} duration={1.6} format={false} suffix="/40" />
            </span>
            <p class="annotation annotation-dim mt-3">ORGANS ADMITTED</p>
          </div>
        </Reveal>
        <Reveal delay={0.1}>
          <div class="border border-[var(--color-border)] p-6 hover:border-[var(--color-border-bright)] transition-colors">
            <span class="font-mono text-4xl md:text-5xl text-[var(--color-bone)] tabular-nums">
              <CountUp client:visible to={10434} duration={2.4} />
            </span>
            <p class="annotation annotation-dim mt-3">LINES OF RUST</p>
          </div>
        </Reveal>
        <Reveal delay={0.2}>
          <div class="border border-[var(--color-border)] p-6 hover:border-[var(--color-border-bright)] transition-colors">
            <span class="font-mono text-4xl md:text-5xl text-[var(--color-bone)] tabular-nums">
              <CountUp client:visible to={369} duration={2.0} />
            </span>
            <p class="annotation annotation-dim mt-3">TESTS</p>
          </div>
        </Reveal>
        <Reveal delay={0.3}>
          <div class="border border-[var(--color-border)] p-6 hover:border-[var(--color-signal-green)] transition-colors">
            <span class="font-mono text-4xl md:text-5xl text-[var(--color-signal-green)] tabular-nums">
              <CountUp client:visible to={0} duration={0.5} format={false} />
            </span>
            <p class="annotation annotation-dim mt-3">.UNWRAP() IN SRC</p>
          </div>
        </Reveal>
      </div>

      {/* Architecture cross-section — NERV Terminal Dogma inspired */}
      <div class="border border-[var(--color-border)] p-6 md:p-8">
        <span class="annotation annotation-dim block mb-4">FIG 02 · ANATOMY CROSS-SECTION</span>
        <pre class="terminal-frame !border-0 !p-0 !bg-transparent text-xs md:text-sm"><code>{`L5 ┃ BINARY          nika                                        ░░░░░░
L4 ┃ INTERFACES      cli · lsp · serve · init · lints            ░░░░░░
L3 ┃ ORCHESTRATION   runtime · daemon                            ░░░░░░
L2 ┃ DOMAIN          verb-exec · fetch · invoke · infer · agent  ░░░░░░
L1 ┃ EFFECTS         fs · http · process · blob · clock · crypto ░░░░░░
L0.5 KERNEL          kernel · kernel-mock                        ██████
L0 ┃ FOUNDATIONS     error · catalog · schema · binding · event  ██░░░░
    ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                     ██ admitted    ░░ growing`}</code></pre>
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-5">
        <a href="https://github.com/supernovae-st/nika" class="border border-[var(--color-signal-green)] p-4 hover:bg-[var(--color-signal-green)]/5 transition-colors">
          <span class="annotation text-[var(--color-signal-green)] block mb-1">nika-error</span>
          <span class="text-xs text-[var(--color-bone-mute)]">L0 · 1,013 LOC · 44 tests</span>
        </a>
        <a href="https://github.com/supernovae-st/nika" class="border border-[var(--color-signal-green)] p-4 hover:bg-[var(--color-signal-green)]/5 transition-colors">
          <span class="annotation text-[var(--color-signal-green)] block mb-1">nika-catalog</span>
          <span class="text-xs text-[var(--color-bone-mute)]">L0 · 3,741 LOC · 138 tests</span>
        </a>
        <a href="https://github.com/supernovae-st/nika" class="border border-[var(--color-signal-green)] p-4 hover:bg-[var(--color-signal-green)]/5 transition-colors">
          <span class="annotation text-[var(--color-signal-green)] block mb-1">nika-kernel</span>
          <span class="text-xs text-[var(--color-bone-mute)]">L0.5 · 3,375 LOC · 99 tests</span>
        </a>
        <a href="https://github.com/supernovae-st/nika" class="border border-[var(--color-signal-green)] p-4 hover:bg-[var(--color-signal-green)]/5 transition-colors">
          <span class="annotation text-[var(--color-signal-green)] block mb-1">nika-kernel-mock</span>
          <span class="text-xs text-[var(--color-bone-mute)]">L0.5 · 1,705 LOC · 88 tests</span>
        </a>
        <div class="border border-[var(--color-border)] border-dashed p-4 opacity-60">
          <span class="annotation annotation-dim block mb-1">nika-schema</span>
          <span class="text-xs text-[var(--color-dim-star)]">L0 · ~12k LOC · next</span>
        </div>
      </div>

      <p class="text-sm text-[var(--color-bone-mute)] mt-8">
        Numbers grep-verified from the <code class="font-mono text-xs px-1 bg-[var(--color-space-sunken)] border border-[var(--color-border)]">nika-diamond</code> branch.
        Full inventory at <a href="https://docs.nika.sh/reference/crates" class="text-[var(--color-nika-orange)]">docs.nika.sh/reference/crates</a>.
      </p>
    </div>
  </section>

  {/* ========================================================================
      RECENT DEV LOGS — 3 most recent changelog entries
      ======================================================================== */}
  {changelogEntries.length > 0 && (
    <section class="border-t border-[var(--color-border)]">
      <div class="mx-auto max-w-[72rem] px-6 py-20">
        <div class="flex items-baseline justify-between mb-10 flex-wrap gap-4">
          <div>
            <span class="annotation annotation-dim block mb-2">§ 04 · WHAT GREW</span>
            <h2 class="font-mono text-2xl leading-tight">Latest dev logs</h2>
          </div>
          <a
            href="/changelog"
            class="font-mono text-sm uppercase tracking-[0.08em] text-[var(--color-nika-orange)] hover:text-[var(--color-chrysalis-amber)]"
          >
            All logs →
          </a>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          {changelogEntries.map((entry) => (
            <article class="border border-[var(--color-border)] p-6 hover:border-[var(--color-border-bright)] transition-colors">
              <span class="annotation annotation-dim block mb-3">
                WEEK {String(entry.data.week).padStart(2, '0')} · {entry.data.date.toISOString().slice(0, 10)}
              </span>
              <h3 class="font-mono text-lg leading-snug mb-3">
                <a href={`/changelog/${entry.id}`} class="hover:text-[var(--color-nika-orange)]">
                  {entry.data.title}
                </a>
              </h3>
              <p class="text-sm text-[var(--color-bone-mute)] line-clamp-3">{entry.data.summary}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ========================================================================
      CTA strip — the single action on this page
      ======================================================================== */}
  <section class="border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-[72rem] px-6 py-24 text-center">
      <p class="annotation annotation-orange mb-4">◆ WELCOME INSIDE THE CHRYSALIS</p>
      <p class="font-display text-3xl md:text-5xl leading-tight max-w-[28ch] mx-auto mb-8">
        We publish every Friday.<br />
        You can read the commits.
      </p>
      <a
        href="https://github.com/supernovae-st/nika"
        class="inline-flex items-center gap-2 font-mono text-sm uppercase tracking-[0.08em] px-5 py-3 border border-[var(--color-bone)] text-[var(--color-bone)] hover:bg-[var(--color-bone)] hover:text-[var(--color-space-navy)] transition-colors"
      >
        github.com/supernovae-st/nika
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </section>
</BaseLayout>
