---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Rule from '~/components/ui/Rule.astro';
import HairlineCard from '~/components/ui/HairlineCard.astro';
import PressButton from '~/components/ui/PressButton.astro';
import CommitTicker from '~/components/ui/CommitTicker.astro';
import ProviderGrid from '~/components/ui/ProviderGrid.astro';
import HeroAscii from '~/components/react/HeroAscii';
import BrailleSpinner from '~/components/react/BrailleSpinner';
import LiveStat from '~/components/react/LiveStat';
import SplitReveal from '~/components/react/SplitReveal';
import CrateConstellation from '~/components/react/CrateConstellation';
import Oscilloscope from '~/components/react/Oscilloscope';
import HorizontalTimeline from '~/components/react/HorizontalTimeline';
import VerbExplorer from '~/components/react/VerbExplorer';
import DitheringCanvas from '~/components/react/DitheringCanvas';
import InstallSnippet from '~/components/react/InstallSnippet';
import { getCollection } from 'astro:content';
import dashboard from '~/data/dashboard.stub.json';

const changelogEntries = (await getCollection('changelog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Fallback values when real dashboard data hasn't been written yet
const STATS = {
  organsAdmitted: dashboard.total_crates_admitted || 5,
  organsPlanned:  dashboard.total_crates_planned  || 40,
  loc:            dashboard.total_loc             || 10434,
  tests:          dashboard.total_tests           || 369,
  unwraps:        dashboard.total_unwraps         || 0,
};
---

<BaseLayout
  title="Nika"
  description="Nika is alive — a semantic YAML workflow engine for AI. One Rust binary, five verbs, nine providers. AGPL forever."
  section=""
>
  {/* =====================================================================
      § 00 — HERO
      ASCII flow field + overlaid editorial headline. The hero IS the
      signature: real text, selectable, driven by a 3-octave FBM shader.
      SplitReveal on the headline: simplex-noise character stagger.
      ===================================================================== */}
  <section class="relative overflow-hidden grain-overlay isolate">
    <div class="absolute inset-0 z-0">
      <HeroAscii client:load cols={160} rows={46} speed={1} />
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: linear-gradient(180deg, var(--color-bg) 0%, transparent 18%, transparent 68%, var(--color-bg) 100%), radial-gradient(ellipse 60% 70% at 15% 30%, oklch(0.62 0.195 258 / 0.08), transparent 70%);"
        aria-hidden="true"
      ></div>
    </div>

    <div class="relative z-10 mx-auto max-w-[82rem] px-6 pt-20 pb-28 md:pt-24 md:pb-36">
      <div class="max-w-3xl">

        <div class="mb-10">
          <a
            href="/changelog/"
            class="inline-flex items-center gap-2.5 h-8 px-3
                   border border-[var(--color-border-bright)]
                   [border-radius:var(--radius-hair)]
                   bg-[var(--color-surface)]
                   hover:border-[oklch(0.62_0.195_258_/_0.4)]
                   hover:bg-[var(--color-surface-2)]
                   transition-colors no-underline"
            aria-label="Latest changelog entry"
          >
            <span
              class="w-1.5 h-1.5 rounded-full bg-[var(--color-emerald)] shrink-0"
              style="box-shadow: 0 0 6px var(--color-emerald-glow); animation: pulse 2.5s ease-in-out infinite;"
              aria-hidden="true"
            ></span>
            <BrailleSpinner client:load />
            <span class="text-[0.67rem] tracking-[0.1em] uppercase text-[var(--color-fg-mute)] font-[var(--font-mono)]">
              nika grew &nbsp;·&nbsp; week 01 &nbsp;·&nbsp; nika-error admitted
            </span>
            <span class="text-[var(--color-fg-ghost)] text-[0.67rem]">→</span>
          </a>
        </div>

        <h1 class="relative">
          <span class="block mono-display mono-display-xl text-[var(--color-fg)]">
            NIKA
          </span>
          <span
            class="block font-[var(--font-display)] font-normal tracking-[-0.035em] leading-[0.92] text-[var(--color-fg)] mt-2"
            style="font-size: clamp(2.5rem, 1.5rem + 6vw, 7rem);"
          >
            is{' '}
            <SplitReveal
              client:load
              text="alive"
              className="editorial text-[var(--color-fg)] italic"
              maxDelay={0.45}
            />{'.'}
          </span>
        </h1>

        <p class="mt-8 max-w-[44ch] text-lg md:text-xl leading-[1.55] text-[var(--color-fg-mute)]">
          A semantic YAML workflow engine for AI — <em class="editorial text-[var(--color-fg)]">five verbs</em>, nine providers, one Rust
          binary. AGPL forever. Watch it <em class="editorial text-[var(--color-fg)]">grow</em>.
        </p>

        {/* Install snippet — primary hero CTA, OS-detected */}
        <div class="mt-10 relative">
          {/* Ambient glow halo behind snippet */}
          <div
            class="absolute pointer-events-none -z-10"
            style="inset: -2rem -3rem; background: radial-gradient(ellipse 75% 90% at 25% 55%, oklch(0.62 0.195 258 / 0.18) 0%, transparent 65%); filter: blur(20px);"
            aria-hidden="true"
          />
          <InstallSnippet client:load />
        </div>

        {/* Secondary CTAs */}
        <div class="mt-6 flex flex-wrap items-center gap-3">
          <PressButton variant="ghost" href="/method/">
            Read the method&nbsp;→
          </PressButton>
          <a
            href="/install/"
            class="inline-flex items-center gap-1.5 text-[0.72rem] text-[var(--color-fg-dim)] hover:text-[var(--color-fg-mute)] transition-colors font-[var(--font-mono)] tracking-[0.06em] uppercase"
          >
            Full guide&nbsp;<span aria-hidden="true">↗</span>
          </a>
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-2 text-[0.7rem] uppercase tracking-[0.14em] text-[var(--color-fg-dim)] font-[var(--font-mono)]">
          <span>AGPL-3.0</span>
          <span class="text-[var(--color-fg-ghost)]">·</span>
          <span>Rust</span>
          <span class="text-[var(--color-fg-ghost)]">·</span>
          <span>macOS · Linux</span>
          <span class="text-[var(--color-fg-ghost)]">·</span>
          <span>9 providers</span>
          <span class="text-[var(--color-fg-ghost)]">·</span>
          <span>Single binary</span>
        </div>
      </div>
    </div>
  </section>

  {/* =====================================================================
      § TICKER — Bloomberg commit tape
      Sits between hero and vital signs, full-width.
      ===================================================================== */}
  <CommitTicker />

  {/* =====================================================================
      § 01 — VITAL SIGNS (live stats + oscilloscope)
      ===================================================================== */}
  <section id="vital-signs" class="edge-rule-bottom">
    <div class="mx-auto max-w-[82rem] px-6 py-16 md:py-20">
      <Rule number="01" label="§ VITAL SIGNS" variant="faint" class="mb-12" />

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-12">
        <div class="stat-cell stat-cell-reveal" data-reveal>
          <div class="flex items-baseline gap-1">
            <LiveStat client:visible to={STATS.organsAdmitted} />
            <span class="mono-display mono-display-md text-[var(--color-fg-dim)]">/{STATS.organsPlanned}</span>
          </div>
          <div class="mt-3 text-xs tracking-[0.14em] uppercase text-[var(--color-fg-mute)] font-[var(--font-mono)]">organs admitted</div>
        </div>
        <div class="stat-cell stat-cell-reveal" data-reveal data-delay="1">
          <LiveStat client:visible to={STATS.loc} />
          <div class="mt-3 text-xs tracking-[0.14em] uppercase text-[var(--color-fg-mute)] font-[var(--font-mono)]">lines of Rust</div>
        </div>
        <div class="stat-cell stat-cell-reveal" data-reveal data-delay="2">
          <LiveStat client:visible to={STATS.tests} />
          <div class="mt-3 text-xs tracking-[0.14em] uppercase text-[var(--color-fg-mute)] font-[var(--font-mono)]">tests passing</div>
        </div>
        <div class="stat-cell stat-cell-reveal" data-reveal data-delay="3">
          <LiveStat client:visible to={STATS.unwraps} />
          <div class="mt-3 text-xs tracking-[0.14em] uppercase text-[var(--color-fg-mute)] font-[var(--font-mono)]">.unwrap() in src</div>
        </div>
      </div>

      {/* Oscilloscope trace — driven by test count */}
      <div class="flex flex-col gap-2">
        <div class="text-[0.68rem] uppercase tracking-[0.14em] text-[var(--color-fg-ghost)] font-[var(--font-mono)]">
          test signal · {STATS.tests} passing
        </div>
        <Oscilloscope
          client:visible
          value={STATS.tests}
          accent={STATS.loc}
          height={72}
          label={`Oscilloscope: ${STATS.tests} tests, ${STATS.loc} LOC`}
        />
      </div>
    </div>
  </section>

  {/* =====================================================================
      § 02 — WORKFLOWS ARE TEXT (YAML demo)
      ===================================================================== */}
  <section class="edge-rule-bottom">
    <div class="mx-auto max-w-[82rem] px-6 py-24 md:py-32">
      <Rule number="02" label="§ A WORKFLOW" variant="faint" class="mb-12" />

      <div class="grid lg:grid-cols-[0.9fr_1.4fr] gap-12 lg:gap-16 items-start">
        <div>
          <h2 class="font-[var(--font-display)] font-normal text-4xl md:text-5xl leading-[1.02] tracking-[-0.025em] text-[var(--color-fg)]">
            Workflows are <em class="editorial">text</em>.
          </h2>
          <p class="mt-6 text-[var(--color-fg-mute)] leading-[1.65] max-w-[42ch]">
            A task has an <code class="inline-code">id</code>, one verb, and an
            optional <code class="inline-code">depends_on</code>. Tasks form a DAG.
            Nika executes in topological order, parallelises what it can,
            streams events as it goes — the same YAML is read by the engine
            and understood by the human.
          </p>
          <div class="mt-8">
            <PressButton variant="ghost" href="/method/">
              Read the method&nbsp;→
            </PressButton>
          </div>
        </div>

        <HairlineCard edge chamfer="tr" class="!p-0 overflow-hidden">
          <div class="flex items-center gap-2 px-4 py-3 edge-rule-bottom bg-[var(--color-sunken)]">
            <span class="inline-block w-2.5 h-2.5 [border-radius:1px] bg-[var(--color-brand)]" aria-hidden="true"></span>
            <span class="text-[0.7rem] uppercase tracking-[0.14em] text-[var(--color-fg-dim)] font-[var(--font-mono)]">
              triage.nika.yaml
            </span>
            <span class="ml-auto text-[0.7rem] text-[var(--color-fg-dim)] font-[var(--font-mono)]">v0.12</span>
          </div>
          <pre class="p-6 font-[var(--font-mono)] text-[0.86rem] leading-[1.65] text-[var(--color-fg)] overflow-x-auto whitespace-pre">
<span class="text-[var(--color-fg-dim)]"># nika grew this workflow — 4 tasks, 1 DAG</span>
<span class="text-[var(--color-cyan)]">schema</span>: nika/workflow@<span class="text-[var(--color-emerald)]">0.12</span>
<span class="text-[var(--color-cyan)]">workflow</span>: triage

<span class="text-[var(--color-cyan)]">tasks</span>:
  - <span class="text-[var(--color-cyan)]">id</span>: classify
    <span class="text-[var(--color-cyan)]">infer</span>:
      <span class="text-[var(--color-cyan)]">provider</span>: anthropic
      <span class="text-[var(--color-cyan)]">model</span>: claude-opus-4-6
      <span class="text-[var(--color-cyan)]">prompt</span>: <span class="text-[var(--color-emerald)]">"Classify issue: &#123;&#123; inputs.body &#125;&#125;"</span>
      <span class="text-[var(--color-cyan)]">structured</span>: &#123; <span class="text-[var(--color-cyan)]">label</span>: string, <span class="text-[var(--color-cyan)]">priority</span>: enum &#125;

  - <span class="text-[var(--color-cyan)]">id</span>: label
    <span class="text-[var(--color-cyan)]">depends_on</span>: [classify]
    <span class="text-[var(--color-cyan)]">invoke</span>:
      <span class="text-[var(--color-cyan)]">tool</span>: gh.label
      <span class="text-[var(--color-cyan)]">input</span>: <span class="text-[var(--color-emerald)]">"&#123;&#123; tasks.classify.output &#125;&#125;"</span></pre>
        </HairlineCard>
      </div>
    </div>
  </section>

  {/* =====================================================================
      § 03 — HOW IT RUNS (execution model)
      Four explicit steps: Write → Parse → Schedule → Stream.
      Static HTML — no React island.
      ===================================================================== */}
  <section id="how-it-runs" class="edge-rule-bottom">
    <div class="mx-auto max-w-[82rem] px-6 py-20 md:py-28">
      <Rule number="03" label="§ HOW IT RUNS" variant="faint" class="mb-12" />

      <div class="grid lg:grid-cols-[1fr_2fr] gap-12 lg:gap-20 items-start mb-16">
        <div>
          <h2 class="font-[var(--font-display)] font-normal text-4xl md:text-5xl leading-[1.02] tracking-[-0.025em] text-[var(--color-fg)]">
            Four steps.<br /><em class="editorial">No hidden state</em>.
          </h2>
          <p class="mt-6 text-[var(--color-fg-mute)] leading-[1.65] max-w-[42ch]">
            The execution model is explicit. Every task declares its inputs, runs exactly one verb, and streams its result. No magic, no callbacks, no surprises.
          </p>
        </div>
      </div>

      {/* 4-step flow grid */}
      <div class="grid grid-cols-2 md:grid-cols-4 border border-[var(--color-border)] bg-[var(--color-border)]" style="gap:1px;" data-reveal>
        <div class="bg-[var(--color-surface)] p-7 flex flex-col gap-4"
          style="box-shadow: inset 0 2px 0 0 var(--color-brand);">
          <div class="mono-display mono-display-sm text-[var(--color-brand)]">01 · WRITE</div>
          <h3 class="font-[var(--font-display)] font-medium text-lg text-[var(--color-fg)] leading-[1.3]">A text file</h3>
          <p class="text-[0.875rem] text-[var(--color-fg-mute)] leading-[1.65]">
            Your workflow is a YAML file. Human-readable, version-controllable, diffable. No GUI required.
          </p>
        </div>
        <div class="bg-[var(--color-surface)] p-7 flex flex-col gap-4"
          style="box-shadow: inset 0 2px 0 0 var(--color-cyan);">
          <div class="mono-display mono-display-sm text-[var(--color-cyan)]">02 · PARSE</div>
          <h3 class="font-[var(--font-display)] font-medium text-lg text-[var(--color-fg)] leading-[1.3]">Build the DAG</h3>
          <p class="text-[0.875rem] text-[var(--color-fg-mute)] leading-[1.65]">
            Nika validates schema, resolves <code class="inline-code">depends_on</code> edges, and constructs a directed acyclic graph.
          </p>
        </div>
        <div class="bg-[var(--color-surface)] p-7 flex flex-col gap-4"
          style="box-shadow: inset 0 2px 0 0 var(--color-emerald);">
          <div class="mono-display mono-display-sm text-[var(--color-emerald)]">03 · SCHEDULE</div>
          <h3 class="font-[var(--font-display)] font-medium text-lg text-[var(--color-fg)] leading-[1.3]">Run in parallel</h3>
          <p class="text-[0.875rem] text-[var(--color-fg-mute)] leading-[1.65]">
            Topological sort determines order. Independent branches run concurrently. Blocked tasks wait.
          </p>
        </div>
        <div class="bg-[var(--color-surface)] p-7 flex flex-col gap-4"
          style="box-shadow: inset 0 2px 0 0 var(--color-violet);">
          <div class="mono-display mono-display-sm text-[var(--color-violet)]">04 · STREAM</div>
          <h3 class="font-[var(--font-display)] font-medium text-lg text-[var(--color-fg)] leading-[1.3]">Events flow out</h3>
          <p class="text-[0.875rem] text-[var(--color-fg-mute)] leading-[1.65]">
            As each task starts and finishes, structured events stream out. Output binds to task IDs for downstream use.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* =====================================================================
      § 04 — FIVE VERBS (interactive verb explorer)
      ===================================================================== */}
  <section id="five-verbs" class="edge-rule-bottom">
    <div class="mx-auto max-w-[82rem] px-6 py-24 md:py-32">
      <Rule number="04" label="§ FIVE VERBS" variant="faint" class="mb-12" />

      <div class="grid lg:grid-cols-[1fr_2.5fr] gap-12 lg:gap-16 items-start mb-12">
        <div>
          <h2 class="font-[var(--font-display)] font-normal text-4xl md:text-5xl leading-[1.02] tracking-[-0.025em] text-[var(--color-fg)]">
            Five verbs.<br /><em class="editorial">Closed set</em>.
          </h2>
          <p class="mt-6 text-[var(--color-fg-mute)] leading-[1.65] max-w-[38ch]">
            Every workflow is a DAG of tasks. Every task uses exactly one verb.
            The schema is the contract — nothing leaks outside it.
          </p>
        </div>
        <div class="text-[0.75rem] text-[var(--color-fg-ghost)] font-[var(--font-mono)] tracking-[0.08em] uppercase pt-2">
          ← click a verb to see its syntax
        </div>
      </div>

      <VerbExplorer client:visible />
    </div>
  </section>

  {/* =====================================================================
      § 05 — THE SHAPE OF NIKA (3 cards)
      ===================================================================== */}
  <section class="edge-rule-bottom">
    <div class="mx-auto max-w-[82rem] px-6 py-20 md:py-28">
      <Rule number="05" label="§ THE SHAPE" variant="faint" class="mb-12" />

      <div class="max-w-3xl mb-12">
        <h2 class="font-[var(--font-display)] font-normal text-4xl md:text-5xl leading-[1.02] tracking-[-0.025em] text-[var(--color-fg)]">
          Three rules. Nothing <em class="editorial">else</em>.
        </h2>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        <HairlineCard chamfer="tl">
          <div class="mono-display mono-display-sm text-[var(--color-brand)] mb-5">
            01 · SEMANTIC
          </div>
          <h3 class="font-[var(--font-display)] font-medium text-xl mb-3 text-[var(--color-fg)]">
            Five verbs. Closed set.
          </h3>
          <p class="text-[0.925rem] text-[var(--color-fg-mute)] leading-[1.65]">
            <code class="inline-code">exec</code>, <code class="inline-code">fetch</code>, <code class="inline-code">invoke</code>,
            <code class="inline-code">infer</code>, <code class="inline-code">agent</code>.
            The schema is the contract. No DSL, no callbacks, no Python pretending to be config.
          </p>
        </HairlineCard>

        <HairlineCard chamfer="tl" brand>
          <div class="mono-display mono-display-sm text-[var(--color-brand)] mb-5">
            02 · SOVEREIGN
          </div>
          <h3 class="font-[var(--font-display)] font-medium text-xl mb-3 text-[var(--color-fg)]">
            One binary. Your keys.
          </h3>
          <p class="text-[0.925rem] text-[var(--color-fg-mute)] leading-[1.65]">
            No daemon. No cloud. Your keys live in your keychain — Anthropic,
            OpenAI, Google, Mistral, Ollama, local GGUF. AGPL: yours forever,
            forkable in anger.
          </p>
        </HairlineCard>

        <HairlineCard chamfer="tl">
          <div class="mono-display mono-display-sm text-[var(--color-brand)] mb-5">
            03 · CRAFTED
          </div>
          <h3 class="font-[var(--font-display)] font-medium text-xl mb-3 text-[var(--color-fg)]">
            Twelve gates. Zero <code class="inline-code">unwrap</code>.
          </h3>
          <p class="text-[0.925rem] text-[var(--color-fg-mute)] leading-[1.65]">
            Every crate passes SPEC → TDD → IMPL → CLIPPY → MUTATION (≥90%) → 7
            more. Built in public, week by week. Chrysalis is not a beta —
            it's the witnessed growth of an organ toward <em class="editorial">emerge</em>.
          </p>
        </HairlineCard>
      </div>
    </div>
  </section>

  {/* =====================================================================
      § 06 — BUILD WITH NIKA (use cases)
      Four concrete things you can build with 5 verbs.
      ===================================================================== */}
  <section class="edge-rule-bottom">
    <div class="mx-auto max-w-[82rem] px-6 py-24 md:py-32">
      <Rule number="06" label="§ BUILD" variant="faint" class="mb-12" />

      <div class="grid lg:grid-cols-[1fr_2fr] gap-12 lg:gap-20 items-start mb-14">
        <div>
          <h2 class="font-[var(--font-display)] font-normal text-4xl md:text-5xl leading-[1.02] tracking-[-0.025em] text-[var(--color-fg)]">
            What you <em class="editorial">build</em>.
          </h2>
          <p class="mt-6 text-[var(--color-fg-mute)] leading-[1.65] max-w-[38ch]">
            Five verbs cover everything from a 4-line shell script to a fully autonomous multi-agent pipeline.
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <HairlineCard chamfer="tl" class="hairline-glow-brand" data-reveal>
          <div class="mono-display mono-display-sm text-[var(--color-brand)] mb-4">DevOps</div>
          <h3 class="font-[var(--font-display)] font-medium text-xl mb-3 text-[var(--color-fg)]">
            GitHub triage bot
          </h3>
          <p class="text-[0.9rem] text-[var(--color-fg-mute)] leading-[1.65] mb-5">
            <code class="inline-code">infer</code> classifies the issue body. <code class="inline-code">invoke</code> applies labels and assigns reviewers. Runs on every new issue, zero glue code.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="pill pill-cyan">INFER</span>
            <span class="pill pill-emerald">INVOKE</span>
          </div>
        </HairlineCard>

        <HairlineCard chamfer="tr" class="hairline-glow-cyan" data-reveal data-delay="1">
          <div class="mono-display mono-display-sm text-[var(--color-cyan)] mb-4">CI/CD</div>
          <h3 class="font-[var(--font-display)] font-medium text-xl mb-3 text-[var(--color-fg)]">
            Release pipeline
          </h3>
          <p class="text-[0.9rem] text-[var(--color-fg-mute)] leading-[1.65] mb-5">
            <code class="inline-code">exec</code> runs your build. <code class="inline-code">fetch</code> polls the status API. <code class="inline-code">invoke</code> cuts the release. All wired in one YAML file.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="pill pill-brand">EXEC</span>
            <span class="pill pill-cyan">FETCH</span>
            <span class="pill pill-emerald">INVOKE</span>
          </div>
        </HairlineCard>

        <HairlineCard chamfer="tl" class="hairline-glow-violet" data-reveal data-delay="2">
          <div class="mono-display mono-display-sm text-[var(--color-violet)] mb-4">AI Research</div>
          <h3 class="font-[var(--font-display)] font-medium text-xl mb-3 text-[var(--color-fg)]">
            Autonomous research agent
          </h3>
          <p class="text-[0.9rem] text-[var(--color-fg-mute)] leading-[1.65] mb-5">
            <code class="inline-code">agent</code> searches and reads sources. <code class="inline-code">infer</code> synthesises a structured report. Runs overnight, no babysitting.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="pill pill-violet">AGENT</span>
            <span class="pill pill-violet">INFER</span>
          </div>
        </HairlineCard>

        <HairlineCard chamfer="tr" class="hairline-glow-emerald" data-reveal data-delay="3">
          <div class="mono-display mono-display-sm text-[var(--color-emerald)] mb-4">Local AI</div>
          <h3 class="font-[var(--font-display)] font-medium text-xl mb-3 text-[var(--color-fg)]">
            Offline data pipeline
          </h3>
          <p class="text-[0.9rem] text-[var(--color-fg-mute)] leading-[1.65] mb-5">
