---
/**
 * EditorialTopBar — the editorial replacement for the floating glass pill.
 *
 * Fixed top band, hairline bottom rule, full-width bleed with inside
 * container. Left: logomark + name in Departure Mono. Center: link list
 * in Geist Mono uppercase small. Right: GitHub icon + press-flat CTA.
 *
 * No glass. No blur. No backdrop-filter. Sharp corners, hairline rule.
 */

interface NavLink {
  href: string;
  label: string;
}

interface Props {
  links?: NavLink[];
  currentSection?: string;
  ctaLabel?: string;
  ctaHref?: string;
  githubHref?: string;
}

const {
  links = [
    { href: '/method/',    label: 'Method' },
    { href: '/changelog/', label: 'Changelog' },
    { href: '/blog/',      label: 'Blog' },
    { href: '/install/',   label: 'Install' },
  ],
  currentSection,
  ctaLabel = 'Install',
  ctaHref = '/install/',
  githubHref = 'https://github.com/supernovae-st/nika',
} = Astro.props;
---

<header
  class="fixed top-0 inset-x-0 z-50 edge-rule-bottom bg-[oklch(0.10_0.015_258_/_0.78)]
         [backdrop-filter:saturate(140%)_blur(2px)]
         [-webkit-backdrop-filter:saturate(140%)_blur(2px)]"
  aria-label="Primary"
>
  <div class="mx-auto max-w-[82rem] px-6 h-12 flex items-center gap-8">

    <a href="/" class="flex items-baseline gap-2 group shrink-0" aria-label="Nika home">
      <span
        class="inline-block w-3 h-3 bg-[var(--color-brand)]
               group-hover:rotate-45 transition-transform duration-300 [border-radius:1px]"
        aria-hidden="true"
      ></span>
      <span class="mono-display mono-display-sm text-[var(--color-fg)]">Nika</span>
      <span class="mono-display mono-display-sm text-[var(--color-fg-dim)] hidden sm:inline">
        /&nbsp;chrysalis
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-0" aria-label="Sections">
      {links.map((link, i) => {
        const active = currentSection?.toLowerCase() === link.label.toLowerCase();
        return (
          <>
            {i > 0 && <span class="text-[var(--color-fg-ghost)] px-1" aria-hidden="true">/</span>}
            <a
              href={link.href}
              class:list={[
                'px-2 py-1 text-[0.75rem] uppercase tracking-[0.08em] font-normal',
                'transition-colors',
                'font-[var(--font-mono)]',
                active
                  ? 'text-[var(--color-fg)]'
                  : 'text-[var(--color-fg-mute)] hover:text-[var(--color-fg)]',
              ]}
              aria-current={active ? 'page' : undefined}
            >{link.label}</a>
          </>
        );
      })}
    </nav>

    <div class="ml-auto flex items-center gap-3">
      <a
        href={githubHref}
        class="hidden md:inline-flex w-8 h-8 items-center justify-center
               text-[var(--color-fg-mute)] hover:text-[var(--color-fg)]
               hover:bg-[oklch(1_0_0_/_0.04)] transition-colors [border-radius:2px]"
        aria-label="GitHub"
        rel="noopener"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0a12 12 0 00-3.79 23.4c.6.11.82-.26.82-.58v-2c-3.34.73-4.04-1.6-4.04-1.6-.55-1.4-1.34-1.77-1.34-1.77-1.1-.74.08-.73.08-.73 1.21.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5 1 .1-.78.42-1.3.76-1.6-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23.96-.27 2-.4 3.02-.4s2.06.13 3.02.4c2.3-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.7.82.58A12 12 0 0012 0z"/>
        </svg>
      </a>
      <a href={ctaHref} class="press-flat press-flat-brand">
        {ctaLabel}
        <span aria-hidden="true" class="text-[var(--color-fg)]/70">→</span>
      </a>
    </div>
  </div>
</header>
