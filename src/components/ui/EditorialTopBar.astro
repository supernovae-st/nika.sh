---
/**
 * EditorialTopBar — floating detached nav.
 *
 * Fixed position with 12px margin from top edge, horizontal padding so the
 * pill doesn't reach the viewport corners. Chamfer top-right corner (Chrysalis
 * grammar), hairline border, subtle box-shadow.
 *
 * The outer <header> is pointer-events-none so clicks pass through transparent
 * edges; the inner pill is pointer-events-auto.
 */

interface NavLink {
  href: string;
  label: string;
}

interface Props {
  links?: NavLink[];
  currentSection?: string;
  ctaLabel?: string;
  ctaHref?: string;
  githubHref?: string;
}

const {
  links = [
    { href: '/method/',    label: 'Method' },
    { href: '/changelog/', label: 'Changelog' },
    { href: '/blog/',      label: 'Blog' },
    { href: '/install/',   label: 'Install' },
  ],
  currentSection,
  ctaLabel = 'Install',
  ctaHref = '/install/',
  githubHref = 'https://github.com/supernovae-st/nika',
} = Astro.props;
---

<header
  class="fixed top-3 left-0 right-0 z-50 px-4 md:px-6 pointer-events-none"
  aria-label="Primary navigation"
>
  <div
    class="mx-auto max-w-[82rem] px-5 h-11 flex items-center gap-6
           pointer-events-auto
           bg-[oklch(0.09_0.015_258_/_0.92)]
           [backdrop-filter:saturate(180%)_blur(18px)]
           [-webkit-backdrop-filter:saturate(180%)_blur(18px)]
           border border-[var(--color-border-bright)]
           shadow-[0_8px_32px_-4px_oklch(0_0_0_/_0.55),0_0_0_1px_oklch(1_0_0_/_0.04)_inset]
           [clip-path:polygon(0_0,calc(100%-12px)_0,100%_12px,100%_100%,0_100%)]"
  >

    <a href="/" class="flex items-baseline gap-2 group shrink-0" aria-label="Nika home">
      <span
        class="inline-block w-2.5 h-2.5 bg-[var(--color-brand)]
               group-hover:rotate-45 transition-transform duration-300 [border-radius:1px]"
        aria-hidden="true"
      ></span>
      <span class="mono-display mono-display-sm text-[var(--color-fg)]">Nika</span>
      <span class="mono-display mono-display-sm text-[var(--color-fg-ghost)] hidden sm:inline">
        /&nbsp;chrysalis
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-0 flex-1" aria-label="Sections">
      {links.map((link, i) => {
        const active = currentSection?.toLowerCase() === link.label.toLowerCase();
        return (
          <>
            {i > 0 && <span class="text-[var(--color-fg-ghost)] px-1 text-[0.65rem]" aria-hidden="true">/</span>}
            <a
              href={link.href}
              class:list={[
                'px-2.5 py-1 text-[0.72rem] uppercase tracking-[0.08em]',
                'transition-colors font-[var(--font-mono)]',
                active
                  ? 'text-[var(--color-fg)]'
                  : 'text-[var(--color-fg-mute)] hover:text-[var(--color-fg)]',
              ]}
              aria-current={active ? 'page' : undefined}
            >{link.label}</a>
          </>
        );
      })}
    </nav>

    <div class="ml-auto flex items-center gap-2">
      {/* ⌘K hint — desktop only */}
      <span
        class="hidden lg:flex items-center gap-1.5 text-[0.62rem] text-[var(--color-fg-ghost)]
               font-[var(--font-display-mono-stack)] tracking-[0.08em] mr-2"
        aria-hidden="true"
      >
        <kbd class="border border-[var(--color-border-bright)] rounded-[3px] px-1.5 py-0.5
                    text-[var(--color-fg-dim)] font-[inherit] text-[0.6rem]">⌘K</kbd>
      </span>

      <a
        href={githubHref}
        class="hidden md:inline-flex w-7 h-7 items-center justify-center
               text-[var(--color-fg-mute)] hover:text-[var(--color-fg)]
               hover:bg-[oklch(1_0_0_/_0.05)] transition-colors [border-radius:2px]"
        aria-label="GitHub"
        rel="noopener noreferrer"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0a12 12 0 00-3.79 23.4c.6.11.82-.26.82-.58v-2c-3.34.73-4.04-1.6-4.04-1.6-.55-1.4-1.34-1.77-1.34-1.77-1.1-.74.08-.73.08-.73 1.21.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5 1 .1-.78.42-1.3.76-1.6-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23.96-.27 2-.4 3.02-.4s2.06.13 3.02.4c2.3-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.7.82.58A12 12 0 0012 0z"/>
        </svg>
      </a>
      <a href={ctaHref} class="press-flat press-flat-brand !text-[0.7rem] !py-1 !px-3">
        {ctaLabel}
        <span aria-hidden="true" class="text-[var(--color-fg)]/70">→</span>
      </a>
    </div>
  </div>
</header>
