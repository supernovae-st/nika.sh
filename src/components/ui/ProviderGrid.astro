---
/**
 * ProviderGrid — thirteen canonical LLM provider cards.
 *
 * Per nika/spec/stdlib/providers-v0.1.md (canonical 13: 7 cloud + 5 local + 1 test).
 * Admitted providers have a live blue indicator.
 * Planned providers are dim with a dashed border.
 * Static Astro — zero client JS.
 */

type Status = 'admitted' | 'planned';

interface Provider {
  id: string;
  name: string;
  status: Status;
  models: string[];
  note?: string;
}

// The canonical 13 · per nika/spec/stdlib/providers-v0.1.md (committed HEAD).
// Cloud (7) · anthropic · openai · mistral · groq · deepseek · gemini · xai
// Local (5) · ollama · lmstudio · llamacpp · localai · vllm
// Test  (1) · mock
const PROVIDERS: Provider[] = [
  // ── Cloud ───────────────────────────────────────────────────────────────
  {
    id: 'anthropic',
    name: 'Anthropic',
    status: 'admitted',
    models: ['claude-opus-4-6', 'claude-sonnet-4-6', 'claude-haiku-4-5'],
  },
  {
    id: 'openai',
    name: 'OpenAI',
    status: 'admitted',
    models: ['gpt-4o', 'gpt-4o-mini', 'o1-mini'],
  },
  {
    id: 'gemini',
    name: 'Gemini',
    status: 'admitted',
    models: ['gemini-2.5-pro', 'gemini-2.0-flash'],
    note: 'Google · long context · multimodal',
  },
  {
    id: 'mistral',
    name: 'Mistral',
    status: 'admitted',
    models: ['mistral-large-2', 'mistral-small'],
    note: 'EU · sovereign-leaning',
  },
  {
    id: 'groq',
    name: 'Groq',
    status: 'planned',
    models: ['llama-3.3-70b', 'mixtral-8x7b'],
    note: 'fastest open-weight',
  },
  {
    id: 'deepseek',
    name: 'DeepSeek',
    status: 'planned',
    models: ['deepseek-r1', 'deepseek-v3'],
    note: 'reasoning · cost-efficient',
  },
  {
    id: 'xai',
    name: 'xAI',
    status: 'planned',
    models: ['grok-4', 'grok-3'],
  },
  // ── Local · sovereign-first ────────────────────────────────────────────
  {
    id: 'ollama',
    name: 'Ollama',
    status: 'admitted',
    models: ['any local model'],
    note: 'localhost:11434 · no key',
  },
  {
    id: 'llamacpp',
    name: 'llama.cpp',
    status: 'admitted',
    models: ['any GGUF model'],
    note: 'llama-server · localhost:8080',
  },
  {
    id: 'lmstudio',
    name: 'LM Studio',
    status: 'planned',
    models: ['any loaded model'],
    note: 'localhost:1234 · no key',
  },
  {
    id: 'localai',
    name: 'LocalAI',
    status: 'planned',
    models: ['any compatible model'],
    note: 'OpenAI drop-in · multi-backend',
  },
  {
    id: 'vllm',
    name: 'vLLM',
    status: 'planned',
    models: ['any HF model'],
    note: 'high-throughput · self-hosted',
  },
  // ── Test ────────────────────────────────────────────────────────────────
  {
    id: 'mock',
    name: 'mock',
    status: 'admitted',
    models: ['deterministic fixture'],
    note: 'no LLM call · test only',
  },
];

const admitted = PROVIDERS.filter(p => p.status === 'admitted');
const planned  = PROVIDERS.filter(p => p.status === 'planned');
---

<div class="provider-grid-wrap">
  {/* Admitted row */}
  <div class="provider-grid">
    {admitted.map(p => (
      <div class="provider-card provider-card--admitted hairline">
        <div class="provider-status-row">
          <span class="provider-dot provider-dot--admitted" aria-hidden="true"></span>
          <span class="provider-status-label">admitted</span>
        </div>
        <div class="provider-name">{p.name}</div>
        <ul class="provider-models" aria-label={`${p.name} models`}>
          {p.models.map(m => (
            <li class="provider-model">{m}</li>
          ))}
        </ul>
        {p.note && <div class="provider-note">{p.note}</div>}
      </div>
    ))}
  </div>

  {/* Planned row */}
  <div class="provider-grid provider-grid--planned">
    {planned.map(p => (
      <div class="provider-card provider-card--planned">
        <div class="provider-status-row">
          <span class="provider-dot provider-dot--planned" aria-hidden="true"></span>
          <span class="provider-status-label">planned</span>
        </div>
        <div class="provider-name">{p.name}</div>
        <ul class="provider-models" aria-label={`${p.name} models`}>
          {p.models.map(m => (
            <li class="provider-model">{m}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</div>
