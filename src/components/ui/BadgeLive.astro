---
/**
 * BadgeLive — glass pill with a pulsing brand dot.
 * Verified Nexus live-status pattern. Narrative-driven copy: the dot sells
 * "alive", the words carry the milestone.
 */

interface Props {
  label: string;
  href?: string;
  dotColor?: 'brand' | 'emerald' | 'amber';
}

const { label, href, dotColor = 'brand' } = Astro.props;

const dotClass = {
  brand: 'bg-[var(--color-brand)] shadow-[0_0_8px_var(--color-brand)]',
  emerald: 'bg-[oklch(0.69_0.150_160)] shadow-[0_0_8px_oklch(0.69_0.150_160)]',
  amber: 'bg-[oklch(0.77_0.160_71)] shadow-[0_0_8px_oklch(0.77_0.160_71)]',
}[dotColor];

const Tag = href ? 'a' : 'span';
---

<Tag
  href={href}
  class="inline-flex items-center gap-3 rounded-full tactile-glass px-3 py-1.5
         text-xs text-[var(--color-fg-mute)] hover:text-[var(--color-fg)]
         transition-colors no-underline"
>
  <span class={`relative inline-flex h-2 w-2 rounded-full ${dotClass}`}>
    <span class={`absolute inline-flex h-full w-full rounded-full opacity-75 animate-ping ${dotClass}`} aria-hidden="true"></span>
  </span>
  <span>{label}</span>
</Tag>
