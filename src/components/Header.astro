---
interface Props {
  currentSection?: string;
}
const { currentSection } = Astro.props;

const links = [
  { href: '/method/',    label: 'Method' },
  { href: '/changelog/', label: 'Changelog' },
  { href: '/blog/',      label: 'Blog' },
  { href: '/install/',   label: 'Install' },
];
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-[var(--color-bg)]/75 border-b border-[var(--color-border)]">
  <div class="mx-auto max-w-[78rem] px-6 h-14 flex items-center justify-between gap-8">
    <a href="/" class="flex items-center gap-2 group" aria-label="Nika home">
      <div class="w-6 h-6 rounded-md bg-gradient-to-br from-[var(--color-brand)] to-[var(--color-cyan)] grid place-items-center">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M2 11V3l5 8 5-8v8" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="text-base font-semibold text-[var(--color-fg)] tracking-tight">
        Nika
      </span>
    </a>

    <nav class="hidden sm:flex items-center gap-1" aria-label="Primary">
      {links.map((link) => {
        const isActive = currentSection?.toLowerCase() === link.label.toLowerCase();
        return (
          <a
            href={link.href}
            class={`px-3 py-1.5 rounded-md text-sm transition-colors
                    ${isActive
                      ? 'text-[var(--color-fg)] bg-[var(--color-surface-2)]'
                      : 'text-[var(--color-fg-mute)] hover:text-[var(--color-fg)]'}`}
            aria-current={isActive ? 'page' : undefined}
          >
            {link.label}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="https://github.com/supernovae-st/nika"
        class="hidden md:inline-flex text-sm text-[var(--color-fg-mute)] hover:text-[var(--color-fg)]"
        aria-label="GitHub"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0a12 12 0 00-3.79 23.4c.6.11.82-.26.82-.58v-2c-3.34.73-4.04-1.6-4.04-1.6-.55-1.4-1.34-1.77-1.34-1.77-1.1-.74.08-.73.08-.73 1.21.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5 1 .1-.78.42-1.3.76-1.6-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23.96-.27 2-.4 3.02-.4s2.06.13 3.02.4c2.3-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.7.82.58A12 12 0 0012 0z"/>
        </svg>
      </a>
      <a href="/install/" class="btn-primary !py-1.5 !px-3 !text-sm">
        Install
      </a>
    </div>
  </div>
</header>
