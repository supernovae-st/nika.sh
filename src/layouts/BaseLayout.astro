---
import '~/styles/global.css';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import CursorFx from '~/components/react/CursorFx';
import CommandPalette from '~/components/react/CommandPalette';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  section?: string;
}

const {
  title,
  description = 'Nika — a semantic YAML workflow engine for AI. AGPL, Rust, runs on your laptop.',
  ogImage = '/og-default.png',
  noindex = false,
  section,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const titleFull = title === 'Nika' ? 'Nika — workflow engine for AI' : `${title} · Nika`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{titleFull}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Favicon */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Nika" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={titleFull} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content="en_US" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titleFull} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    {/* Theme color for mobile browsers */}
    <meta name="theme-color" content="#0B0D17" />

    {/* astro:fonts — Geist (body) + Geist Mono (code) + Instrument Serif (italic accent) + Departure Mono (display) */}
    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-display-mono" preload />
    <Font cssVariable="--font-mono" />
    <Font cssVariable="--font-serif" />

    {/* Sitemap */}
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* RSS */}
    <link rel="alternate" type="application/rss+xml" title="Nika Changelog" href="/changelog.xml" />

    {/* View Transitions — directional slide between pages */}
    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-[var(--color-nika-orange)] focus:text-[var(--color-space-navy)] focus:px-4 focus:py-2 focus:font-mono focus:text-sm">
      Skip to content
    </a>

    {/* Scroll progress — thin brand line, CSS scroll-timeline */}
    <div class="scroll-progress" aria-hidden="true"></div>

    {/* ⌘K Command palette — keyboard-first navigation */}
    <CommandPalette client:load />

    {/* Magnetic cursor — pointer:fine only, no-ops on touch */}
    <CursorFx client:load />

    <Header currentSection={section} />

    <main id="main" class="pt-12">
      <slot />
    </main>

    <Footer />
  </body>
</html>
