  nkd:semantic "A when: gate held it back" ;
  nkd:lucideGlyph "circle-slash" ;
  nkd:centralGlyph "interface-general/circle-minus" ;
  nkd:servedAt <https://nika.sh/brand/icons/state-skipped.svg> .

