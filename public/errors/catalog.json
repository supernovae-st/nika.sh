{
  "$schema": "https://nika.sh/schema/errors-catalog.json",
  "version": 2,
  "updated": "2026-06-10",
  "description": "Nika error namespace catalog · derived from the language spec (nika-spec spec/05-errors.md · normative). Errors are typed structures: stable code, category, transient flag. Format NIKA-<NAMESPACE>-<NNN> (optional sub-namespace · regex ^NIKA-[A-Z]{2,9}(-[A-Z]{2,9})?-[0-9]{3}$). Per-code entries will be generated by the engine's nika-error crate at GA.",
  "spec": "https://github.com/supernovae-st/nika-spec/blob/main/spec/05-errors.md",
  "namespaces": {
    "NIKA-PARSE": {
      "scope": "YAML parse + envelope validation",
      "range": "001-099"
    },
    "NIKA-DAG": {
      "scope": "DAG topology · cycles · invalid deps",
      "range": "001-099"
    },
    "NIKA-VAR": {
      "scope": "Variable resolution failures",
      "range": "001-099"
    },
    "NIKA-INFER": {
      "scope": "infer: verb errors",
      "range": "001-099"
    },
    "NIKA-EXEC": {
      "scope": "exec: verb errors",
      "range": "001-099"
    },
    "NIKA-INVOKE": {
      "scope": "invoke: verb errors",
      "range": "001-099"
    },
    "NIKA-AGENT": {
      "scope": "agent: verb errors",
      "range": "001-099"
    },
    "NIKA-PROVIDER": {
      "scope": "Provider adapter errors",
      "range": "001-099 per provider"
    },
    "NIKA-BUILTIN": {
      "scope": "Builtin tool errors · per-builtin sub-namespace (NIKA-BUILTIN-WAIT-001)",
      "range": "001-099 per builtin"
    },
    "NIKA-MCP": {
      "scope": "MCP client errors",
      "range": "001-099"
    },
    "NIKA-SEC": {
      "scope": "Security policy violations (SSRF · blocklist)",
      "range": "001-099"
    },
    "NIKA-TIMEOUT": {
      "scope": "Task or step timeouts",
      "range": "001-099"
    },
    "NIKA-CANCEL": {
      "scope": "Task or workflow cancellation",
      "range": "001-099"
    },
    "NIKA-IMPL": {
      "scope": "Engine internal errors",
      "range": "001-099"
    }
  },
  "error_shape": {
    "code": "stable greppable identifier (NIKA-INFER-001)",
    "category": "closed enum (provider_error · network_error · …)",
    "message": "human-readable",
    "transient": "bool · true = retry might help (engine retries with backoff)",
    "details": "structured fields · on_error: can act on them",
    "task_id": "the failing task",
    "attempt": "retry attempt number"
  }
}
